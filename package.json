{
  "name": "control-center-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "postinstall": "nx reset && nx build ng-configs && cd dist/libs/ng-configs && npm i",
    "start": "nx serve control-center --port 4200",
    "prod": "cross-env NODE_ENV=stage nx serve control-center --port 4200 --configuration=production",
    "stage": "cross-env NODE_ENV=stage nx serve control-center --port 4201 --configuration=stage",
    "build": "nx run-many -t build",
    "test": "nx test",
    "lint": "nx run-many -t lint",
    "lint:fix": "npm run lint -- --fix=true",
    "format": "nx format",
    "format:fix": "nx format:write",
    "spell": "cspell --no-progress **",
    "spell:unused": "npx cspell-check-unused-words",
    "spell:fix": "npm run spell -- **  --show-suggestions --show-context",
    "fix": "npm run lint:fix && npm run format:fix && npm run spell:fix",
    "check": "concurrently --prefix \"[{command}]\" --prefixColors auto --prefixLength 20 \"npm run format\" \"npm run lint\" \"npm run spell\""
  },
  "dependencies": {
    "@angular/animations": "19.2.4",
    "@angular/cdk": "19.2.7",
    "@angular/common": "19.2.4",
    "@angular/compiler": "19.2.4",
    "@angular/core": "19.2.4",
    "@angular/forms": "19.2.4",
    "@angular/material": "19.2.7",
    "@angular/material-date-fns-adapter": "19.2.7",
    "@angular/platform-browser": "19.2.4",
    "@angular/platform-browser-dynamic": "19.2.4",
    "@angular/router": "19.2.4",
    "@ngneat/input-mask": "6.1.0",
    "@vality/deanonimus-proto": "2.0.1-6605c72.0",
    "@vality/domain-proto": "2.0.1-pr-161-cac07c8.0",
    "@vality/dominator-proto": "1.0.1-41bee97.0",
    "@vality/fistful-proto": "2.0.1-f2ca9b5.0",
    "@vality/machinegun-proto": "1.0.1-3decc8f.0",
    "@vality/magista-proto": "2.0.2-e49ad10.0",
    "@vality/repairer-proto": "2.0.2-07b73e9.0",
    "@vality/scrooge-proto": "0.1.1-9ce7fc6.0",
    "@vality/thrift-ts": "2.4.1-8ad5123.0",
    "@vality/woody": "0.1.3",
    "date-fns": "^3.6.0",
    "keycloak-angular": "^19.0.2",
    "keycloak-js": "^20.0.5",
    "lodash-es": "^4.17.21",
    "monaco-editor": "^0.52.2",
    "rxjs": "7.8.2",
    "short-uuid": "4.2.2",
    "tslib": "2.8.1",
    "utility-types": "3.11.0",
    "zone.js": "0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "19.2.5",
    "@angular-devkit/core": "19.2.5",
    "@angular-devkit/schematics": "19.2.5",
    "@angular/cli": "~19.2.0",
    "@angular/compiler-cli": "19.2.4",
    "@nx/angular": "20.6.4",
    "@nx/eslint-plugin": "20.6.4",
    "@nx/jest": "20.6.4",
